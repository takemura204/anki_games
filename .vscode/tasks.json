{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "Generate New Feature",
			"type": "shell",
			"command": "./script/generate_feature.sh",
			"args": ["${input:featureName}"],
			"presentation": {
				"reveal": "always",
				"panel": "new"
			},
			"options": {
				"cwd": "${workspaceFolder}"
			},
			"problemMatcher": []
		},
		{
			"label": "build_runner watch",
			"type": "shell",
			"command": "dart run build_runner watch --delete-conflicting-outputs",
			"options": {
				"cwd": "${workspaceFolder}"
			},
			"isBackground": true,
			"presentation": {
				"reveal": "always",
				"panel": "dedicated",
				"showReuseMessage": false
			},
			"problemMatcher": []
		},
		{
			"label": "bring-flutter-target-to-front",
			"type": "shell",
			"command": "${workspaceFolder}/script/bring_flutter_target_to_front.sh",
			"windows": {
				"command": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File \"${workspaceFolder}\\script\\bring_flutter_target_to_front.ps1\""
			},
			"options": {
				"cwd": "${workspaceFolder}"
			},
			"presentation": {
				"reveal": "silent",
				"panel": "shared",
				"showReuseMessage": false
			},
			"problemMatcher": []
		}
	],
	"inputs": [
		{
			"id": "featureName",
			"description": "機能名を入力してください (例: home, user_profile)",
			"default": "hoge",
			"type": "promptString"
		}
	]
}
