{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Generate New Feature",
      "type": "shell",
      "command": "./script/generate_feature.sh",
      "args": [
        "${input:featureName}"
      ],
      "presentation": {
        "reveal": "always",
        "panel": "new"
      },
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    }
  ],
  "inputs": [
    {
      "id": "featureName",
      "description": "機能名を入力してください (例: home, user_profile)",
      "default": "hoge",
      "type": "promptString"
    }
  ]
}